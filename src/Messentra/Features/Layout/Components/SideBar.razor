@using Messentra.Domain
<div>
    <MudDrawer Open="true"
               Variant="@DrawerVariant.Persistent"
               Elevation="1"
               ClipMode="DrawerClipMode.Always"
               Class="overflow-hidden">
        <MudDrawerContainer Class="mud-height-full pa-4 d-flex flex-column">
            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Class="mb-3 logo-container">
                <MudImage Src="@Assets["logo.svg"]" Fluid="true" Alt="Logo"/>
            </MudStack>
            <MudDivider Class="drawer-divider" />
    
            <MudNavMenu Color="Color.Primary"
                        Class="pt-3">
                @foreach (var link in _links)
                {
                    @if (link.Href == "/jobs")
                    {
                        var runningJobsCount = _jobState.Value.Jobs.Count(j => j.Status is JobStatus.Queued or JobStatus.Running);
                        <MudNavLink Href="@link.Href"
                                    Icon="@(link.IsDisabled ? Icons.Material.Outlined.Block : link.Icon)"
                                    Disabled="@link.IsDisabled">
                            <MudBadge Class="mud-width-full" Content="@runningJobsCount" Color="Color.Secondary" Origin="Origin.CenterRight"  Visible="@(runningJobsCount > 0)">
                                <MudText>@link.Title</MudText>
                            </MudBadge>
                        </MudNavLink>
                    }
                    else
                    {
                        <MudNavLink Href="@link.Href"
                                    Icon="@(link.IsDisabled ? Icons.Material.Outlined.Block : link.Icon)"
                                    Disabled="@link.IsDisabled">
                            <MudText>@link.Title</MudText>
                        </MudNavLink>
                    }
                }
            </MudNavMenu>

            <MudStack AlignItems="AlignItems.Center" Justify="Justify.FlexEnd" Class="mud-height-full">
                <MudTooltip Text="@(_themeState.Value.IsDarkMode ? "Switch to light mode" : "Switch to dark mode")">
                    <MudIconButton
                        Icon="@ThemeToggleIcon"
                        Size="Size.Small"
                        Color="Color.Inherit"
                        Ripple="false"
                        OnClick="@OnToggleTheme"/>
                </MudTooltip>
                <UpdateNotification />
            </MudStack>
            
        </MudDrawerContainer>
    </MudDrawer>
</div>
