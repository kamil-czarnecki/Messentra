@using Messentra.Features.Explorer.Resources
@using Messentra.Features.Explorer.Folders
@using MudBlazor.Utilities

<div class="namespace-tree">
    <MudPaper Elevation="0" Class="d-flex align-center justify-space-between pa-2">
        <MudText Typo="Typo.h6">Namespaces</MudText>
        <MudMenu Icon="@Icons.Material.Filled.Add"
                 Size="Size.Small"
                 Color="Color.Primary"
                 Dense="true"
                 AnchorOrigin="Origin.BottomRight"
                 TransformOrigin="Origin.TopRight"
                 FullWidth="true">
            <ChildContent>
                @{
                    var availableConnections = Connections
                        .Where(x => Resources.All(r => r.Text != x.Name))
                        .ToList();
                }

                <MudMenuItem Icon="@Icons.Material.Rounded.AddCircle" IconColor="Color.Primary" OnClick="@OpenConnections">
                    <MudText Color="Color.Primary" Typo="Typo.body2"><b>Add connection</b></MudText>
                </MudMenuItem>
                @if (availableConnections.Count != 0)
                {
                    <MudDivider/>
                    <MudText Typo="Typo.caption" Class="text-secondary ml-2"><b>SAVED CONNECTIONS</b></MudText>
                }
                @foreach (var connection in availableConnections)
                {
                    <MudMenuItem Icon="@Icons.Material.Filled.Dns" IconColor="Color.Default" OnClick="@(() => SelectConnection(connection))">
                        <MudStack Spacing="0">
                            <MudText Typo="Typo.body2">@connection.Name</MudText>
                            <MudText Typo="Typo.caption" Color="Color.Primary">@connection.ConnectionConfig.GetNamespace()</MudText>
                        </MudStack>
                    </MudMenuItem>
                }
            </ChildContent>
        </MudMenu>
    </MudPaper>
    <MudDivider Class="border-2"/>
    @if (Resources.Count == 0)
    {
        <MudStack AlignItems="AlignItems.Center" Class="ma-2 mud-height-full dashed-border" Justify="Justify.Center">
            <MudIcon Icon="@Icons.Material.Rounded.CloudOff" Size="Size.Large" Color="Color.Default"/>
            <MudText Typo="Typo.body2" Align="Align.Center" Class="text-secondary">
                No connection selected
            </MudText>
            <MudText Typo="Typo.caption" Inline="true" Align="Align.Center" Class="text-secondary">
                Click the <MudText Typo="Typo.caption" Color="Color.Primary">+</MudText> button to add a connection and start exploring your Azure Service Bus resources.
            </MudText>
        </MudStack>
    }
    else
    {
        <MudHotkey Key="JsKey.F5" OnHotkeyPressed="@(() => RefreshHotkeyClicked())"/>
        <MudAutocomplete T="string"
                         Class="mx-2"
                         Dense="true"
                         Value="@_localSearchPhrase"
                         ValueChanged="@OnSuggestionSelected"
                         TextChanged="@OnTextChanged"
                         SearchFunc="@SuggestSearchPhrases"
                         CoerceValue="true"
                         ResetValueOnEmptyText="true"
                         MinCharacters="0"
                         MaxItems="10"
                         Immediate="true"
                         Clearable="true"
                         DebounceInterval="300"
                         Typo="Typo.caption"
                         Adornment="Adornment.Start"
                         IconSize="Size.Small"
                         AdornmentIcon="@Icons.Material.Filled.Search">
            <ItemTemplate Context="option">
                @{
                    var token = option.Trim().Split(' ').LastOrDefault() ?? option;
                }
                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                    <MudIcon Icon="@GetSuggestionIcon(token)" Size="Size.Small" Color="Color.Primary"/>
                    <MudText Typo="Typo.body2">@token</MudText>
                </MudStack>
            </ItemTemplate>
        </MudAutocomplete>
        @if (_contextMenuOpen)
        {
            <div style="position:fixed;inset:0;z-index:1000;"
                 @onclick="CloseContextMenu"
                 @oncontextmenu="CloseContextMenu"
                 @oncontextmenu:preventDefault/>
            <MudPaper Elevation="4"
                      Style="@($"position:fixed;left:{_contextMenuX}px;top:{_contextMenuY}px;z-index:1001;min-width:200px;")">
                @if (_contextFolderNode is not null)
                {
                    <MudList Dense="true" T="string">
                        <MudListItem Text="Rename" OnClick="@(async () => await OnContextRenameFolder())"/>
                        <MudDivider/>
                        <MudListItem Text="Delete folder" OnClick="OnContextDeleteFolder" Class="mud-error-text"/>
                    </MudList>
                }
                else if (_contextResourceNode is not null)
                {
                    var resourceUrl = GetResourceUrl(_contextResourceNode);
                    var connectionName = GetConnectionName(_contextResourceNode) ?? "";
                    var allFolders = GetAllNodes<FolderTreeNode>(connectionName).ToList();
                    var containingFolders = resourceUrl is not null
                        ? GetFoldersContainingResource(resourceUrl, connectionName).ToList()
                        : new List<FolderTreeNode>();
                    var containingIds = containingFolders.Select(f => f.FolderId).ToHashSet();
                    var availableFolders = allFolders.Where(f => !containingIds.Contains(f.FolderId)).ToList();
                    <MudList Dense="true" T="string">
                        @foreach (var folder in availableFolders)
                        {
                            <MudListItem Text="@($"Add to \"{folder.Name}\"")" OnClick="@(() => OnContextAddToFolder(folder))"/>
                        }
                        @if (availableFolders.Count > 0 && containingFolders.Count > 0)
                        {
                            <MudDivider/>
                        }
                        @foreach (var folder in containingFolders)
                        {
                            <MudListItem Text="@($"Remove from \"{folder.Name}\"")" OnClick="@(() => OnContextRemoveFromFolder(folder))" Class="mud-error-text"/>
                        }
                        @if (allFolders.Count == 0)
                        {
                            <MudListItem Disabled="true" Text="No folders yet — create one first"/>
                        }
                    </MudList>
                }
            </MudPaper>
        }
        <MudTreeView Ripple="false" Items="@FilteredResources" Dense="true" Class="ma-0 pa-0 mud-height-full compact-tree"
                     tabindex="0"
                     @onfocusin="@(() => _isFocused = true)"
                     @onfocusout="@(() => _isFocused = false)">
            <ItemTemplate>
                @{
                    var presenter = (context as ResourceTreeItemData)!;
                }
                <MudTreeViewItem Expanded="@presenter.Expanded"
                                 ExpandedChanged="@(x => OnExpandedChanged(presenter, x))"
                                 Items="@presenter.Children"
                                 Value="@presenter.Value"
                                 Icon="@presenter.Icon"
                                 IconColor="@presenter.IconColor"
                                 Selected="@presenter.Selected"
                                 ReadOnly="@presenter.IsReadonly"
                                 SelectedChanged="@(x => ItemSelected(presenter, x))">
                    <BodyContent Context="node">
                        <MudStack Row="true" Justify="Justify.Center" AlignItems="AlignItems.Center" Class="mud-width-full tree-item-body"
                                  @oncontextmenu="@(e => OnTreeItemRightClick(e, presenter))">
                            <MudText Typo="Typo.caption" Class="flex-grow-1 text-truncate">@presenter.Text</MudText>
                            @if (presenter.Value is { IsLoading: false })
                            {
                                switch (presenter.Value)
                                {
                                    case FoldersTreeNode foldersNode:
                                        <MudIconButton Icon="@Icons.Material.Filled.CreateNewFolder"
                                                       Color="Color.Primary"
                                                       Size="Size.Small"
                                                       Ripple="false"
                                                       Class="folders-add-btn"
                                                       OnClick="@(async () => await OnAddFolderClicked(foldersNode))"/>
                                        break;
                                    case NamespaceTreeNode:
                                        <MudButton Variant="Variant.Text"
                                                   Color="Color.Primary"
                                                   Ripple="false"
                                                   OnClick="@(_ => Disconnect(presenter))"
                                                   Class="disconnect-button">
                                            Disconnect
                                        </MudButton>
                                        break;
                                    case QueuesTreeNode or TopicsTreeNode:
                                        <MudIconButton
                                            Icon="@Icons.Material.Filled.Refresh"
                                            Color="Color.Primary"
                                            Size="Size.Small"
                                            Ripple="false"
                                            OnClick="@(() => OnRefreshClicked(presenter.Value))"/>
                                        break;
                                    default:
                                        <MudText Typo="Typo.caption">
                                            @GetMessageCountText(presenter.Value)
                                        </MudText>
                                        break;
                                }
                            }
                            else
                            {
                                @if (presenter.Value is NamespaceTreeNode namespaceNode)
                                {
                                    <div class="namespace-loading-control">
                                        <MudProgressCircular Class="namespace-loading-icon namespace-loading-spinner" Color="Color.Primary" Indeterminate="true"/>
                                        <MudIconButton Class="namespace-loading-cancel"
                                                       Icon="@Icons.Material.Filled.Stop"
                                                       Color="Color.Error"
                                                       Size="Size.Small"
                                                       OnClick="@(() => OnCancelFetchResourcesClicked(namespaceNode.ConnectionName))" />
                                    </div>
                                }
                                else
                                {
                                    <MudProgressCircular Class="namespace-loading-icon" Color="Color.Primary" Indeterminate="true"/>
                                }
                            }
                        </MudStack>
                    </BodyContent>
                </MudTreeViewItem>
            </ItemTemplate>
        </MudTreeView>
    }
</div>

