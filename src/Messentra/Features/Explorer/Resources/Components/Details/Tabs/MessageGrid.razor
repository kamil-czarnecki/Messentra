@using Messentra.Features.Explorer.Messages
@using MudBlazor.Utilities

<div class="message-grid-container"
     tabindex="0"
     @onfocusin="@(() => _isGridFocused = true)"
     @onfocusout="@(() => _isGridFocused = false)"
     @ref="_gridContainer">
    <MudHotkey Key="JsKey.ArrowUp" OnHotkeyPressed="OnKeyUpPressed"/>
    <MudHotkey Key="JsKey.ArrowDown" OnHotkeyPressed="OnKeyDownPressed"/>
    <MudDataGrid Loading="@_isGridLoading" @ref="_grid" T="ServiceBusMessage" Dense="true" Elevation="0" Virtualize="true"
                 Square="true" Items="@FilteredMessages" @bind-SelectedItems="@SelectedItems" FixedHeader="true" Height="100%"
                 Class="message-grid" MultiSelection="true" ColumnResizeMode="ResizeMode.Container" SortMode="SortMode.Single"
                 SelectOnRowClick="false" RowClassFunc="@((x, _) => GetRowClass(x))" ExpandSingleRow="true"
                 RowClick="@(x => OnRowClick(x.Item))" DragDropColumnReordering="true">
        <ToolBarContent>
            <MudStack Class="mud-width-full" Spacing="1">
                <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Class="mud-width-full">
                    <MudStack Row="true" AlignItems="AlignItems.Center">
                        <MudButton IconSize="Size.Small" Variant="Variant.Filled" Color="Color.Primary" DropShadow="false"
                                   Size="Size.Small" Ripple="false" StartIcon="@Icons.Material.Filled.Download"
                                   OnClick="@OnFetchMessagesClicked" Disabled="@_isFetchOngoing">
                            <MudText Typo="Typo.body2">Fetch</MudText>
                        </MudButton>
                        @if (SubQueue != SubQueue.Active)
                        {
                            <MudButton IconSize="Size.Small" Variant="Variant.Text" StartIcon="@Icons.Material.Filled.MoveUp" Ripple="false"
                                       OnClick="@(() => OnResendClicked(_fetchMessagesOptions is { Mode: FetchMode.Receive, ReceiveMode: FetchReceiveMode.PeekLock }))" Disabled="@(!_selectedMessages.Any() || _actionOngoing)">
                                <MudText Typo="Typo.body2">Resend</MudText>
                            </MudButton>
                        }
                        <MudButton IconSize="Size.Small" Variant="Variant.Text" StartIcon="@Icons.Material.Filled.SaveAlt" Ripple="false"
                                   OnClick="@(OnExportSelectedClicked)" Disabled="@(!_selectedMessages.Any() || _actionOngoing)">
                            <MudText Class="text-no-wrap" Typo="Typo.body2">Export selected</MudText>
                        </MudButton>
                        @if (_fetchMessagesOptions is { Mode: FetchMode.Receive })
                        {
                            <MudHidden Breakpoint="Breakpoint.MdAndDown">
                                <MudButton IconSize="Size.Small" Variant="Variant.Text" StartIcon="@Icons.Material.Filled.Check" Ripple="false"
                                           OnClick="@OnCompleteClicked" Disabled="@(IsReceiveAndDeleteMode || !_selectedMessages.Any() || _actionOngoing)">
                                    <MudText Typo="Typo.body2">Complete</MudText>
                                </MudButton>
                                <MudButton IconSize="Size.Small" Variant="Variant.Text" StartIcon="@Icons.Material.Filled.LockOpen" Ripple="false"
                                           OnClick="@OnAbandonClicked" Disabled="@(IsReceiveAndDeleteMode || !_selectedMessages.Any() || _actionOngoing)">
                                    <MudText Typo="Typo.body2">Abandon</MudText>
                                </MudButton>
                                <MudButton IconSize="Size.Small" Variant="Variant.Text" StartIcon="@Icons.Material.Filled.Delete" Ripple="false"
                                           OnClick="@OnDeadLetterClicked" Disabled="@(IsReceiveAndDeleteMode || !_selectedMessages.Any() || _actionOngoing)">
                                    <MudText Typo="Typo.body2">DeadLetter</MudText>
                                </MudButton>
                            </MudHidden>
                            <MudHidden Breakpoint="Breakpoint.LgAndUp">
                                <MudMenu Icon="@Icons.Material.Filled.MoreVert" Ripple="false" Dense="true">
                                    <MudMenuItem Icon="@Icons.Material.Filled.Check" OnClick="@OnCompleteClicked" Disabled="@(IsReceiveAndDeleteMode || !_selectedMessages.Any() || _actionOngoing)">
                                        <MudText Typo="Typo.body2">Complete</MudText>
                                    </MudMenuItem>
                                    <MudMenuItem Icon="@Icons.Material.Filled.LockOpen" OnClick="@OnAbandonClicked" Disabled="@(IsReceiveAndDeleteMode || !_selectedMessages.Any() || _actionOngoing)">
                                        <MudText Typo="Typo.body2">Abandon</MudText>
                                    </MudMenuItem>
                                    <MudMenuItem Icon="@Icons.Material.Filled.Delete" OnClick="@OnDeadLetterClicked" Disabled="@(IsReceiveAndDeleteMode || !_selectedMessages.Any() || _actionOngoing)">
                                        <MudText Typo="Typo.body2">DeadLetter</MudText>
                                    </MudMenuItem>
                                </MudMenu>
                            </MudHidden>
                        }
                    </MudStack>
                    <MudTextField @key="_searchFieldRenderKey" Typo="Typo.body2" T="string" @bind-Value="SearchTerm" Placeholder="Search" Adornment="Adornment.Start"
                                  AdornmentIcon="@Icons.Material.Filled.Search" IconSize="Size.Small" Class="search" Immediate="true" Clearable="true" DebounceInterval="200"/>
                </MudStack>
                @if (_selectedMessages.Any())
                {
                    <MudText Typo="Typo.caption" Color="Color.Secondary">@_selectedMessages.Count selected</MudText>
                }
            </MudStack>
        </ToolBarContent>
        <Columns>
            <HierarchyColumn T="ServiceBusMessage" Hidden="true"/>
            <SelectColumn T="ServiceBusMessage" Resizable="false"/>
            @foreach (var col in EffectiveColumns)
            {
                <TemplateColumn @key="@col.Id"
                                T="ServiceBusMessage"
                                Title="@col.Title"
                                Sortable="true"
                                SortBy="@(x => GetSortValue(x, col))"
                                Resizable="true"
                                ShowColumnOptions="true"
                                DragAndDropEnabled="@(col.Id != "seq")"
                                HeaderClass="@($"col-{col.Id}")">
                    <HeaderTemplate>
                        <div class="col-header-trigger"
                             @oncontextmenu="@(e => OnColumnHeaderRightClick(e, col))"
                             @oncontextmenu:preventDefault="true">
                            @col.Title
                        </div>
                    </HeaderTemplate>
                    <CellTemplate>
                        <span>@GetCellValue(context.Item, col)</span>
                    </CellTemplate>
                </TemplateColumn>
            }
        </Columns>
        <ChildRowContent>
            <MudTabs Class="message-tabs" Color="Color.Surface" MinimumTabWidth="100px" Ripple="false" Elevation="0"
                     Rounded="false" ApplyEffectsToContainer="true" @bind-ActivePanelIndex="@_activePanelIndex">
                <MudTabPanel Text="Body" Class="pa-0">
                    <MudStack Justify="Justify.Center" Class="pa-6">
                        <JsonViewer Json="@context.Item.Message.Body"/>
                    </MudStack>
                </MudTabPanel>
                <MudTabPanel Text="Properties" Class="pa-0">
                    <MessageProperties Message="@context.Item" SubQueue="@SubQueue"/>
                </MudTabPanel>
            </MudTabs>
        </ChildRowContent>
    </MudDataGrid>
    <MudMenu @ref="_columnMenu" PositionAtCursor="true">
        <ChildContent>
            <MudText Typo="Typo.caption" Class="px-3 pt-2 mud-text-secondary menu-section-label">View</MudText>
            @foreach (var view in Views)
            {
                <MudMenuItem OnClick="@(() => OnSwitchViewClicked(view.Id))">
                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                        @if (view.Id == ActiveViewId)
                        {
                            <MudIcon Icon="@Icons.Material.Filled.Check" Size="Size.Small" Color="Color.Primary"/>
                        }
                        else
                        {
                            <span class="view-checkmark-spacer"/>
                        }
                        <MudText Typo="Typo.body2">@view.Name</MudText>
                    </MudStack>
                </MudMenuItem>
            }
            <MudDivider Class="my-1"/>
            <MudMenuItem OnClick="@OnSaveCurrentViewClicked"
                         Disabled="@(Views.FirstOrDefault(v => v.Id == ActiveViewId)?.IsBuiltIn == true)">
                <MudText Typo="Typo.body2">Save current view</MudText>
            </MudMenuItem>
            <MudMenuItem OnClick="@(async () => await OnSaveViewAsClicked())">
                <MudText Typo="Typo.body2">Save view as…</MudText>
            </MudMenuItem>
            <MudMenuItem OnClick="@(async () => await OnDeleteViewClicked())"
                         Disabled="@(Views.FirstOrDefault(v => v.Id == ActiveViewId)?.IsBuiltIn == true)"
                         Class="mud-error-text">
                <MudText Typo="Typo.body2">Delete "@(Views.FirstOrDefault(v => v.Id == ActiveViewId)?.Name)"</MudText>
            </MudMenuItem>
            <MudDivider Class="my-1"/>
            <MudText Typo="Typo.caption" Class="px-3 pt-1 mud-text-secondary menu-section-label">Column</MudText>
            <MudMenuItem OnClick="@(async () => await OnAddColumnMenuItemClicked())">
                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                    <MudIcon Icon="@Icons.Material.Filled.Add" Size="Size.Small"/>
                    <MudText Typo="Typo.body2">Add column…</MudText>
                </MudStack>
            </MudMenuItem>
            @if (_contextMenuColumn is not null)
            {
                <MudMenuItem OnClick="@OnRemoveColumnMenuItemClicked"
                             Disabled="@(!_contextMenuColumn.IsRemovable)"
                             Class="@(_contextMenuColumn.IsRemovable ? "mud-error-text" : string.Empty)">
                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                        <MudIcon Icon="@Icons.Material.Filled.Close" Size="Size.Small"/>
                        <MudText Typo="Typo.body2">
                            Remove "@_contextMenuColumn.Title"
                            @if (!_contextMenuColumn.IsRemovable) { <span> (locked)</span> }
                        </MudText>
                    </MudStack>
                </MudMenuItem>
            }
        </ChildContent>
    </MudMenu>
</div>
