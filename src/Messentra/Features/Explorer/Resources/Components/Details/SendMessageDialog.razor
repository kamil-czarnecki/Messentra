@using Messentra.Features.Explorer.Messages.SendMessage
<div>
    <MudDialog>
        <DialogContent>
            <MudStack Spacing="2">
                <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="mb-2">
                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1" Class="mb-1">
                        <MudIcon Icon="@Icons.Material.Filled.Description" Size="Size.Small" Color="Color.Primary"/>
                        <MudText Typo="Typo.body2" Class="text-uppercase font-weight-bold">MESSAGE BODY</MudText>
                    </MudStack>
                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                        <MudSelect T="BodyFormat"
                                   @bind-Value="_bodyFormat"
                                   Variant="Variant.Outlined"
                                   Margin="Margin.Dense"
                                   Typo="Typo.body2"
                                   Dense="true">
                            <MudSelectItem Value="BodyFormat.Json">
                                <MudText Typo="Typo.body2">JSON</MudText>
                            </MudSelectItem>
                            <MudSelectItem Value="BodyFormat.PlainText">
                                <MudText Typo="Typo.body2">Plain Text</MudText>
                            </MudSelectItem>
                        </MudSelect>
                        <MudButton Variant="Variant.Outlined"
                                   Size="Size.Small"
                                   StartIcon="@Icons.Material.Filled.FormatAlignLeft"
                                   OnClick="@FormatJson"
                                   Disabled="@(_bodyFormat != BodyFormat.Json)">
                            <MudText Typo="Typo.body2">Format JSON</MudText>
                        </MudButton>
                    </MudStack>
                </MudStack>
                <MudTextField @bind-Value="_body"
                              Variant="Variant.Outlined"
                              Typo="Typo.body2"
                              Lines="8"
                              Margin="Margin.Dense"
                              Placeholder="@(_bodyFormat == BodyFormat.Json ? "{ \"key\": \"value\" }" : "Enter message body...")"
                              Immediate="true"/>
                <MudGrid Spacing="3">
                    <MudItem xs="12" lg="6">
                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1" Class="mb-2">
                            <MudIcon Icon="@Icons.Custom.Brands.MicrosoftAzure" Size="Size.Small" Color="Color.Primary"/>
                            <MudText Typo="Typo.body2" Class="font-weight-bold">BROKER PROPERTIES</MudText>
                        </MudStack>
                        <MudPaper Outlined="true" Class="pa-3">
                            <MudGrid Spacing="2">
                                <MudItem xs="6">
                                    <MudText Typo="Typo.body2">LABEL / SUBJECT</MudText>
                                    <MudTextField @bind-Value="_label"
                                                  Variant="Variant.Outlined"
                                                  Margin="Margin.Dense"
                                                  Typo="Typo.body2"
                                                  Placeholder="e.g. Order_Processed"
                                                  Immediate="true"/>
                                </MudItem>
                                <MudItem xs="6">
                                    <MudText Typo="Typo.body2">CORRELATION ID</MudText>
                                    <MudTextField @bind-Value="_correlationId"
                                                  Variant="Variant.Outlined"
                                                  Typo="Typo.body2"
                                                  Margin="Margin.Dense"
                                                  Placeholder="Optional"
                                                  Immediate="true"/>
                                </MudItem>
                                <MudItem xs="6">
                                    <MudText Typo="Typo.body2"message-tabs>PARTITION KEY</MudText>
                                    <MudTextField @bind-Value="_partitionKey"
                                                  Variant="Variant.Outlined"
                                                  Margin="Margin.Dense"
                                                  Typo="Typo.body2"
                                                  Placeholder="Optional"
                                                  Immediate="true"/>
                                </MudItem>
                                <MudItem xs="6">
                                    <MudText Typo="Typo.body2"message-tabs>SCHEDULED TIME (UTC)</MudText>
                                    <MudDatePicker @bind-Date="_scheduledDate"
                                                   Variant="Variant.Outlined"
                                                   Margin="Margin.Dense"
                                                   Square="true"
                                                   Placeholder="Optional"
                                                   Editable="true"/>
                                </MudItem>
                                <MudItem xs="6">
                                    <MudText Typo="Typo.body2"message-tabs>MESSAGE ID</MudText>
                                    <MudTextField @bind-Value="_messageId"
                                                  Variant="Variant.Outlined"
                                                  Margin="Margin.Dense"
                                                  Placeholder="Optional"
                                                  Typo="Typo.body2"
                                                  Immediate="true"/>
                                </MudItem>
                                <MudItem xs="6">
                                    <MudText Typo="Typo.body2"message-tabs>CONTENT TYPE</MudText>
                                    <MudTextField @bind-Value="_contentType"
                                                  Variant="Variant.Outlined"
                                                  Margin="Margin.Dense"
                                                  Typo="Typo.body2"
                                                  Placeholder="e.g. application/json"
                                                  Immediate="true"/>
                                </MudItem>
                                <MudItem xs="6">
                                    <MudText Typo="Typo.body2"message-tabs>SESSION ID</MudText>
                                    <MudTextField @bind-Value="_sessionId"
                                                  Variant="Variant.Outlined"
                                                  Margin="Margin.Dense"
                                                  Typo="Typo.body2"
                                                  Placeholder="Optional"
                                                  Immediate="true"/>
                                </MudItem>
                                <MudItem xs="6">
                                    <MudText Typo="Typo.body2"message-tabs>REPLY-TO SESSION ID</MudText>
                                    <MudTextField @bind-Value="_replyToSessionId"
                                                  Variant="Variant.Outlined"
                                                  Margin="Margin.Dense"
                                                  Typo="Typo.body2"
                                                  Placeholder="Optional"
                                                  Immediate="true"/>
                                </MudItem>
                                <MudItem xs="6">
                                    <MudText Typo="Typo.body2"message-tabs>TO</MudText>
                                    <MudTextField @bind-Value="_to"
                                                  Variant="Variant.Outlined"
                                                  Margin="Margin.Dense"
                                                  Typo="Typo.body2"
                                                  Placeholder="Optional"
                                                  Immediate="true"/>
                                </MudItem>
                                <MudItem xs="6">
                                    <MudText Typo="Typo.body2"message-tabs>REPLY-TO</MudText>
                                    <MudTextField @bind-Value="_replyTo"
                                                  Variant="Variant.Outlined"
                                                  Margin="Margin.Dense"
                                                  Placeholder="Optional"
                                                  Immediate="true"/>
                                </MudItem>
                                <MudItem xs="12">
                                    <MudText Typo="Typo.body2"message-tabs>TIME TO LIVE</MudText>
                                    <MudTextField @bind-Value="_timeToLiveText"
                                                  Variant="Variant.Outlined"
                                                  Margin="Margin.Dense"
                                                  Typo="Typo.body2"
                                                  Placeholder="Optional (e.g. 00:10:00)"
                                                  Immediate="true"/>
                                </MudItem>
                            </MudGrid>
                        </MudPaper>
                    </MudItem>
                    <MudItem xs="12" lg="6">
                        <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="mb-2">
                            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                                <MudIcon Icon="@Icons.Material.Outlined.Tune" Size="Size.Small" Color="Color.Primary"/>
                                <MudText Typo="Typo.body2" Class="font-weight-bold">CUSTOM PROPERTIES</MudText>
                            </MudStack>
                            <MudButton Variant="Variant.Text"
                                       Size="Size.Small"
                                       StartIcon="@Icons.Material.Filled.AddCircleOutline"
                                       Color="Color.Primary"
                                       OnClick="@AddCustomProperty">
                                <MudText Typo="Typo.body2">ADD ROW</MudText>
                            </MudButton>
                        </MudStack>
                        <MudPaper Outlined="true" Class="custom-props-table" Elevation="0">
                            <MudSimpleTable Dense="true" Hover="false" Elevation="0">
                                <thead>
                                <tr>
                                    <th class="">KEY</th>
                                    <th>VALUE</th>
                                    <th>TYPE</th>
                                    <th></th>
                                </tr>
                                </thead>
                                <tbody>
                                @foreach (var prop in _customProperties)
                                {
                                    <tr>
                                        <td><MudTextField Typo="Typo.body2" @bind-Value="prop.Key" Variant="Variant.Text" Margin="Margin.Dense" Placeholder="New Key..." Immediate="true" /></td>
                                        <td><MudTextField Typo="Typo.body2" @bind-Value="prop.Value" Variant="Variant.Text" Margin="Margin.Dense" Placeholder="New Value..." Immediate="true" /></td>
                                        <td><MudText Typo="Typo.body2">String</MudText></td>
                                        <td><MudIconButton Icon="@Icons.Material.Filled.DeleteOutline" Size="Size.Small" Color="Color.Primary" OnClick="@(() => RemoveCustomProperty(prop))"/></td>
                                    </tr>
                                }
                                </tbody>
                            </MudSimpleTable>
                        </MudPaper>
                    </MudItem>
                </MudGrid>
            </MudStack>
        </DialogContent>
        <DialogActions>
            <MudButton OnClick="@Cancel">Cancel</MudButton>
            <MudButton Color="Color.Primary"
                       Variant="Variant.Filled"
                       OnClick="@Submit"
                       StartIcon="@Icons.Material.Filled.Send">
                Send
            </MudButton>
        </DialogActions>
    </MudDialog>
</div>