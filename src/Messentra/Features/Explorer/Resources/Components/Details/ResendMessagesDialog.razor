<div>
    <MudDialog>
        <DialogContent>
            <div class="resend-layout">
                <MudPaper Outlined="true" Elevation="0" Class="resend-message-list">
                    @foreach (var (message, index) in Messages.Select((m, i) => (m, i)))
                    {
                        <MudListItem T="string"
                                     Class="@($"resend-message-item{(_selectedIndex == index ? " resend-message-item--selected" : "")}")"
                                     OnClick="@(() => _selectedIndex = index)"
                                     Dense="true">
                            <MudStack Spacing="0">
                                <MudText Typo="Typo.body2" Color="@(_selectedIndex == index ? Color.Primary : Color.Default)">SEQ #@message.Message.BrokerProperties.SequenceNumber</MudText>
                                <MudText Typo="Typo.caption" Class="mud-text-secondary">@(message.Message.BrokerProperties.MessageId ?? "(no id)")</MudText>
                            </MudStack>
                        </MudListItem>
                    }
                </MudPaper>
                <div class="resend-form-panel">
                    @if (_models.Count > 0)
                    {
                        <MessageEditForm Model="@_models[_selectedIndex]"/>
                    }
                </div>
            </div>
        </DialogContent>
        <DialogActions>
            <MudButton OnClick="@Cancel">Cancel</MudButton>
            <MudButton Color="Color.Primary"
                       Variant="Variant.Filled"
                       OnClick="@Submit"
                       StartIcon="@Icons.Material.Filled.MoveUp">
                Resend All
            </MudButton>
        </DialogActions>
    </MudDialog>

</div>