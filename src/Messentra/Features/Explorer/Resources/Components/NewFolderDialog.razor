<MudDialog DefaultFocus="DefaultFocus.FirstChild">
    <DialogContent>
        <MudTextField @bind-Value="_folderName"
                      Label="Folder name"
                      Immediate="true"
                      Error="@HasDuplicateName"
                      ErrorText="Folder with this name already exists"
                      Class="folder-name-input"
                      OnKeyUp="@(e => { if (e.Key == "Enter") Confirm(); })"/>

        @if (HasDuplicateName)
        {
            <MudText Typo="Typo.caption" Color="Color.Error" Class="mt-1 folder-name-error">
                Folder with this name already exists
            </MudText>
        }
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="@Cancel">Cancel</MudButton>
        <MudButton Color="Color.Primary"
                   Variant="Variant.Filled"
                   OnClick="@Confirm"
                   Class="folder-create-confirm"
                   Disabled="@IsConfirmDisabled">Create</MudButton>
    </DialogActions>
</MudDialog>
